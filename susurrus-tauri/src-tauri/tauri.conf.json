{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Susurrus",
  "version": "0.0.1",
  "identifier": "io.ludiars.susurrus",
  "build": {
    "beforeBuildCommand": "npm --prefix frontend run build",
    "beforeDevCommand": "npm --prefix frontend run dev",
    "devUrl": "http://127.0.0.1:5176",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Susurrus",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
